## .NET / Visual Studio gitignore
## Based on https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Rr]elease/
[Rr]eleases/
**/[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
bld/
artifacts/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files
*.rsuser
*.userprefs

# Mono
mono_crash.*

# MSTest / NUnit / xUnit
[Tt]est[Rr]esult*/
*.trx
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Benchmark results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Code coverage
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
*.dotCover

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Rider
.idea/

# Build logs
*.binlog
*.log
*.tlog
MSBuild_Logs/

# Windows Installer
*.cab
*.msi
*.msix
*.msm
*.msp

# Misc
*.[Cc]ache
!?*.[Cc]ache/
~$*
*~
*.tmp
*.env
